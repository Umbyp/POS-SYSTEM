# ===== POS API (apps/api) — Production env =====
# คัดลอกค่าจริงไปใส่ใน Render Dashboard → Environment (อย่า commit ค่าจริง)

# --- Database (Supabase) ---
# DATABASE_URL ใช้ตัว POOLED (port 6543, มี ?pgbouncer=true) สำหรับแอป
# DIRECT_URL ใช้ตัว DIRECT (port 5432) สำหรับ prisma migrate
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-1-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-1-xxx.pooler.supabase.com:5432/postgres"

# --- Auth ---
JWT_SECRET="ตั้งรหัสลับยาว ๆ อย่างน้อย 16 ตัวอักษร"
JWT_EXPIRES_IN="7d"

# --- App ---
NODE_ENV=production
# PORT ไม่ต้องตั้ง — Render กำหนดให้อัตโนมัติ
# โดเมนเว็บที่อนุญาต (CORS) — คั่นหลายอันด้วย comma, ใส่ URL ของ Vercel
WEB_URL="https://your-pos-web.vercel.app"

# --- Stripe (PromptPay) ---
# ใช้ sk_live_ ตอน production (sk_test_ สำหรับทดสอบ)
STRIPE_SECRET_KEY="sk_live_xxxxxxxx"
# ได้จาก Stripe Dashboard → Developers → Webhooks หลังสร้าง endpoint
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"

# --- Supabase Storage (เก็บรูปสินค้าถาวร — กันรูปหายตอน redeploy) ---
# ถ้าไม่ตั้ง 2 ตัวล่างนี้ ระบบจะเก็บรูปลงดิสก์ในเครื่องแทน (เหมาะกับ dev เท่านั้น)
# SUPABASE_URL = https://<project-ref>.supabase.co  (ref คือส่วนหลัง postgres. ใน DATABASE_URL)
SUPABASE_URL="https://xxxx.supabase.co"
# Service role key (ลับมาก!) → Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci...service_role..."
# ชื่อ bucket (ไม่ตั้งก็ได้ ค่าเริ่มต้น = product-images, สร้างให้อัตโนมัติ)
SUPABASE_STORAGE_BUCKET="product-images"
