generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String        @id @default(cuid())
  email      String        @unique
  password   String?
  googleId   String?       @unique
  name       String
  avatar     String?
  role       Role          @default(CASHIER)
  storeId    String
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  activities ActivityLog[]
  orders     Order[]
  shifts     Shift[]
  store      Store         @relation(fields: [storeId], references: [id])
  memberOf   StoreMember[]
}

// จับคู่ user กับ store ที่เขา access ได้ (สำหรับ multi-store)
model StoreMember {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([userId])
  @@index([storeId])
}

model Store {
  id            String     @id @default(cuid())
  name          String
  address       String?
  phone         String?
  taxId         String?
  logo          String?
  currency      String     @default("THB")
  taxRate          Float   @default(7.0)
  priceIncludesTax Boolean @default(true)
  serviceCharge    Float   @default(0)
  promptpayId   String?
  invoicePrefix String?
  branchCode    String?
  createdAt     DateTime   @default(now())
  smsWebhookToken String?
  dailyTarget     Decimal  @default(0) @db.Decimal(12, 2)
  monthlyTarget   Decimal  @default(0) @db.Decimal(12, 2)
  // ระบบสะสมแต้ม — ปรับได้ต่อร้าน
  loyaltyMode      String  @default("BOTH") // POINTS | STAMPS | BOTH | OFF
  pointsEarnBaht   Int     @default(100) // ใช้จ่ายกี่บาทได้ 1 แต้ม (0 = ปิดการสะสม)
  pointValue       Decimal @default(1) @db.Decimal(10, 2) // 1 แต้ม แลกส่วนลดกี่บาท
  minRedeemPoints  Int     @default(0)  // ใช้แต้มขั้นต่ำต่อครั้ง (0 = ไม่จำกัด)
  // บัตรสะสมดวง (stamp card) — มา 1 ครั้ง = 1 ดวง
  stampsPerReward  Int     @default(10) // ครบกี่ดวงได้ 1 รางวัล
  stampRewardValue Decimal @default(0) @db.Decimal(10, 2) // รางวัล = ส่วนลดกี่บาทต่อ 1 ใบเต็ม
  stampRewardName  String? // ชื่อรางวัล เช่น "กาแฟฟรี 1 แก้ว"
  members         StoreMember[]
  categories    Category[]
  customers     Customer[]
  orders        Order[]
  products      Product[]
  optionGroups  OptionGroup[]
  promotions    Promotion[]
  suppliers     Supplier[]
  tables        Table[]
  users         User[]
  selfOrderRequests SelfOrderRequest[]
  billCallRequests  BillCallRequest[]
}

model Promotion {
  id          String         @id @default(cuid())
  storeId     String
  name        String
  code        String?        // โค้ดส่วนลดที่ลูกค้ากรอก (optional)
  type        PromotionType
  scope       PromotionScope @default(ALL_ORDER)
  value       Decimal        @default(0) @db.Decimal(10, 2) // % หรือ บาท
  buyQty      Int?           // สำหรับ BUY_X_GET_Y
  getQty      Int?
  productIds  String[]       @default([])
  categoryIds String[]       @default([])
  minSpend    Decimal?       @db.Decimal(10, 2)
  startAt     DateTime?
  endAt       DateTime?
  daysOfWeek  Int[]          @default([])
  hourStart   Int?
  hourEnd     Int?
  memberOnly  Boolean        @default(false)
  isActive    Boolean        @default(true)
  usageLimit  Int?
  usageCount  Int            @default(0)
  createdAt   DateTime       @default(now())
  store       Store          @relation(fields: [storeId], references: [id])

  @@index([storeId, isActive])
  @@index([code])
}

enum PromotionType {
  PERCENT_OFF
  FIXED_OFF
  BUY_X_GET_Y
  FIXED_PRICE
}

enum PromotionScope {
  ALL_ORDER
  CATEGORY
  PRODUCT
}

model Category {
  id        String    @id @default(cuid())
  name      String
  icon      String?
  color     String?
  sortOrder Int       @default(0)
  storeId   String
  createdAt DateTime  @default(now())
  store     Store     @relation(fields: [storeId], references: [id])
  products  Product[]
}

model Product {
  id           String           @id @default(cuid())
  name         String
  sku          String           @unique
  barcode      String?          @unique
  description  String?
  image        String?
  costPrice    Decimal          @db.Decimal(10, 2)
  sellingPrice Decimal          @db.Decimal(10, 2)
  categoryId   String
  storeId      String
  trackStock   Boolean          @default(true)
  isActive     Boolean          @default(true)
  isIngredient Boolean          @default(false)
  isCombo      Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  inventory    Inventory?
  orderItems   OrderItem[]
  category     Category         @relation(fields: [categoryId], references: [id])
  store        Store            @relation(fields: [storeId], references: [id])
  variants     ProductVariant[]
  optionGroups ProductOptionGroup[]
  recipe       RecipeItem[]     @relation("ProductRecipe")
  usedIn       RecipeItem[]     @relation("IngredientFor")

  @@index([categoryId])
  @@index([storeId])
}

// ชุดตัวเลือกกลางของร้าน เช่น "ความหวาน" (เลือก 1) หรือ "ท็อปปิ้ง" (เลือกหลายอย่าง)
// นิยามครั้งเดียว แล้ว attach ไปหลายเมนูได้ผ่าน ProductOptionGroup
model OptionGroup {
  id        String   @id @default(cuid())
  storeId   String
  name      String   // "ความหวาน", "ท็อปปิ้ง"
  minSelect Int      @default(0) // จำนวนขั้นต่ำที่ต้องเลือก (1 = บังคับเลือก)
  maxSelect Int      @default(1) // สูงสุดที่เลือกได้ (1 = เลือกอย่างเดียว, 0 = ไม่จำกัด)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id])
  options   Option[]
  products  ProductOptionGroup[]

  @@index([storeId, isActive])
}

// ตัวเลือกย่อยในกลุ่ม เช่น "หวานน้อย" (+0), "ไข่มุก" (+10)
model Option {
  id         String      @id @default(cuid())
  groupId    String
  name       String
  priceDelta Decimal     @default(0) @db.Decimal(10, 2)
  sortOrder  Int         @default(0)
  isDefault  Boolean     @default(false) // เลือกไว้ให้เป็นค่าเริ่มต้น
  group      OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// จับคู่ชุดตัวเลือกกับเมนู (many-to-many)
model ProductOptionGroup {
  productId String
  groupId   String
  sortOrder Int         @default(0)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  group     OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([productId, groupId])
  @@index([groupId])
}

model RecipeItem {
  id           String  @id @default(cuid())
  productId    String  // เมนูที่ขาย (เช่น ลาเต้)
  ingredientId String  // วัตถุดิบ (เป็น Product เช่นกัน — เมล็ดกาแฟ, นม)
  quantity     Decimal @db.Decimal(10, 3)
  unit         String? // กรัม, มล., ชิ้น, ช้อน
  notes        String?
  product      Product @relation("ProductRecipe", fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Product @relation("IngredientFor", fields: [ingredientId], references: [id])

  @@index([productId])
  @@index([ingredientId])
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  name       String
  priceDelta Decimal @default(0) @db.Decimal(10, 2)
  sku        String?
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inventory {
  id         String          @id @default(cuid())
  productId  String          @unique
  quantity   Int             @default(0)
  lowStockAt Int             @default(10)
  expiryDate DateTime?
  updatedAt  DateTime        @updatedAt
  product    Product         @relation(fields: [productId], references: [id])
  movements  StockMovement[]
}

model StockMovement {
  id          String       @id @default(cuid())
  inventoryId String
  type        MovementType
  quantity    Int
  reason      String?
  orderId     String?
  userId      String?
  createdAt   DateTime     @default(now())
  inventory   Inventory    @relation(fields: [inventoryId], references: [id])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contact        String?
  phone          String?
  email          String?
  storeId        String
  createdAt      DateTime        @default(now())
  purchaseOrders PurchaseOrder[]
  store          Store           @relation(fields: [storeId], references: [id])
}

model PurchaseOrder {
  id         String    @id @default(cuid())
  supplierId String
  status     String    @default("PENDING")
  total      Decimal   @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime  @default(now())
  receivedAt DateTime?
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      // unique per store (see @@unique below), not globally —
                            // two stores' "first order of the day" would otherwise collide
  storeId       String
  cashierId     String
  customerId    String?
  tableId       String?
  promotionId   String?
  promotionName String?
  type          OrderType   @default(DINE_IN)
  status        OrderStatus @default(DRAFT)
  subtotal      Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  promotionDiscount Decimal  @default(0) @db.Decimal(10, 2)
  tax           Decimal     @default(0) @db.Decimal(10, 2)
  serviceCharge Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  pointsRedeemed   Int         @default(0)
  pointsEarned     Int         @default(0)
  stampsEarned     Int         @default(0) // ดวงที่ได้จากบิลนี้ (ไว้ดึงกลับเมื่อ refund)
  stampsRedeemed   Int         @default(0) // ดวงที่ใช้แลกรางวัลในบิลนี้
  notes            String?
  customerName     String?
  customerTaxId    String?
  customerAddress  String?
  createdAt        DateTime    @default(now())
  completedAt      DateTime?
  cashier          User        @relation(fields: [cashierId], references: [id])
  customer      Customer?   @relation(fields: [customerId], references: [id])
  store         Store       @relation(fields: [storeId], references: [id])
  table         Table?      @relation(fields: [tableId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@unique([storeId, orderNumber])
  @@index([storeId, createdAt])
  @@index([status])
  @@index([customerId])
}

model Customer {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  phone       String?
  email       String?
  taxId       String?
  address     String?
  points      Int      @default(0)
  stamps      Int      @default(0) // ดวงบัตรสะสมที่ยังไม่ได้แลก (รีเซ็ตเมื่อแลกรางวัล)
  totalSpent  Decimal  @default(0) @db.Decimal(12, 2)
  visitCount  Int      @default(0)
  lastVisitAt DateTime?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  store       Store    @relation(fields: [storeId], references: [id])
  orders      Order[]
  pointTransactions PointTransaction[]
  selfOrderRequests SelfOrderRequest[]

  @@index([storeId, phone])
  @@index([storeId, name])
}

// บันทึกทุกการเปลี่ยนแปลงแต้มของลูกค้า — source of truth สำหรับประวัติ/ตรวจสอบ
// Customer.points เป็นแค่ยอดสรุป (cache) ที่ต้องอัปเดตคู่กับแถวนี้เสมอในทรานแซกชันเดียว
model PointTransaction {
  id           String      @id @default(cuid())
  storeId      String
  customerId   String
  type         PointTxType
  points       Int         // +ได้แต้ม / -ใช้แต้ม (delta ที่ใช้จริง)
  balanceAfter Int         // ยอดแต้มคงเหลือหลังรายการนี้
  orderId      String?     // อ้างอิงบิลที่ทำให้แต้มเปลี่ยน
  note         String?
  createdBy    String?     // userId พนักงานที่ปรับ (กรณี MANUAL_ADJUST)
  createdAt    DateTime    @default(now())
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([storeId, type])
  @@index([orderId])
}

enum PointTxType {
  EARN            // ได้แต้มจากการซื้อ
  REDEEM          // ใช้แต้มแลกส่วนลด
  REFUND_REVERSAL // คืนเงินบิล → ดึงแต้มที่เคยได้กลับ / คืนแต้มที่เคยใช้
  MANUAL_ADJUST   // พนักงานปรับแต้มเอง
  STAMP_EARN      // ได้ดวงบัตรสะสม (1 ครั้ง = 1 ดวง)
  STAMP_REDEEM    // ใช้ดวงแลกรางวัล (หัก 1 ใบเต็ม)
  STAMP_ADJUST    // พนักงานปรับดวงเอง
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  quantity     Int
  refundedQty  Int      @default(0)
  unitPrice    Decimal  @db.Decimal(10, 2)
  discount     Decimal  @default(0) @db.Decimal(10, 2)
  notes        String?
  variants     Json?
  refundReason String?
  createdAt    DateTime @default(now()) // lets KDS tell "round 2 just fired" from the original order
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  method          PaymentMethod
  amount          Decimal       @db.Decimal(10, 2)
  reference       String?
  slipVerified    Boolean       @default(false)
  slipTransRef    String?       @unique
  slipVerifiedAt  DateTime?
  slipPayload     String?
  createdAt       DateTime      @default(now())
  order           Order         @relation(fields: [orderId], references: [id])
}

model Table {
  id       String  @id @default(cuid())
  number   String
  capacity Int     @default(4)
  size     String  @default("MEDIUM") // SMALL | MEDIUM | LARGE
  status   String  @default("AVAILABLE") // AVAILABLE | RESERVED | OCCUPIED | BILLING | DIRTY
  occupiedAt DateTime? // set when guests are seated; drives elapsed-time badge
  qrCode   String? @unique
  storeId  String
  orders   Order[]
  store    Store   @relation(fields: [storeId], references: [id])
  selfOrderRequests SelfOrderRequest[]
  billCallRequests  BillCallRequest[]
}

// A cart a customer built themselves by scanning a table's QR code, awaiting
// staff approval before it's merged into the table's actual bill (see
// self-order.service.ts) — kept separate from Order so a prank/mistaken
// submission never touches stock or the kitchen until a staff member confirms.
model SelfOrderRequest {
  id           String   @id @default(cuid())
  storeId      String
  tableId      String
  customerId   String?
  items        Json     // [{ productId, quantity, notes? }]
  note         String?
  status       SelfOrderStatus @default(PENDING)
  rejectReason String?
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?
  store        Store    @relation(fields: [storeId], references: [id])
  table        Table    @relation(fields: [tableId], references: [id])
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([storeId, status])
  @@index([customerId])
}

enum SelfOrderStatus {
  PENDING
  APPROVED
  REJECTED
}

// A customer tapping "Call for the bill" from the self-order page — a plain
// notification for staff to come collect payment, not a payment itself
// (payment stays staff-mediated through the normal settle-tab flow).
// Deduped per table: a second tap while one is already PENDING is a no-op.
model BillCallRequest {
  id             String        @id @default(cuid())
  storeId        String
  tableId        String
  status         BillCallStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  acknowledgedAt DateTime?
  store          Store         @relation(fields: [storeId], references: [id])
  table          Table         @relation(fields: [tableId], references: [id])

  @@index([storeId, status])
}

enum BillCallStatus {
  PENDING
  ACKNOWLEDGED
}

model PaymentNotification {
  id              String   @id @default(cuid())
  storeId         String
  amount          Decimal  @db.Decimal(12, 2)
  bank            String?
  senderName      String?
  rawMessage      String
  matchedOrderId  String?
  matched         Boolean  @default(false)
  receivedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([storeId, receivedAt(sort: Desc)])
  @@index([storeId, matched])
}

model Shift {
  id          String    @id @default(cuid())
  userId      String
  startTime   DateTime  @default(now())
  endTime     DateTime?
  openingCash Decimal   @default(0) @db.Decimal(10, 2)
  closingCash Decimal?  @db.Decimal(10, 2)
  cashSales   Decimal   @default(0) @db.Decimal(10, 2)
  totalSales  Decimal   @default(0) @db.Decimal(10, 2)
  notes       String?
  user        User      @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

enum Role {
  OWNER
  ADMIN
  CASHIER
  KITCHEN
}

enum MovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  WASTE
}

enum OrderStatus {
  DRAFT
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  PROMPTPAY
  CREDIT_CARD
  BANK_TRANSFER
}
