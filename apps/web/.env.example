# ===== POS Web (apps/web) — Production env =====
# ตั้งค่าเหล่านี้ใน Vercel → Project Settings → Environment Variables
# ค่า NEXT_PUBLIC_* จะถูกฝังตอน build จึงต้องตั้งก่อน deploy

# URL ของ POS API (Render) — ลงท้ายด้วย /api
NEXT_PUBLIC_API_URL="https://your-pos-api.onrender.com/api"

# URL ของ Analytics API (Render) — ไม่ต้องมี /api
NEXT_PUBLIC_ANALYTICS_API="https://your-analytics-api.onrender.com"

# URL ของหน้าเว็บ Analytics (Vercel) — ใช้สำหรับลิงก์ "Analytics" ใน sidebar
NEXT_PUBLIC_ANALYTICS_URL="https://your-analytics-web.vercel.app"
